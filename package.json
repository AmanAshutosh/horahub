{
  "name": "horahub",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Vedic astrology engine — computed nine-graha charts with sourced, citation-backed interpretation.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && npm run kg:build && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:seed": "tsx prisma/seed.ts",
    "kb:build": "tsx scripts/build-kb.ts",
    "kb:extract": "tsx scripts/kb-extract.ts",
    "kb:segment": "tsx scripts/kb-segment.ts",
    "kb:report": "tsx scripts/kb-report.ts",
    "kb:encode": "tsx scripts/kb-encode.ts",
    "kb:parser-stats": "tsx scripts/kb-parser-stats.ts",
    "kb:index": "tsx scripts/kb-index.ts",
    "kb:conflicts": "tsx scripts/kb-conflicts.ts",
    "kb:summary": "tsx scripts/kb-summary.ts",
    "kg:build": "tsx scripts/kb-build-graph.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@prisma/client": "^5.22.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "next": "^16.2.10",
    "pino": "^9.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "server-only": "^0.0.1",
    "sweph": "^2.10.3-5",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.4",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
