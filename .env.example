# ── Database (Neon / any Postgres) ───────────────────────────────
# Pooled connection — used by the running app.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct connection — used by Prisma migrations only.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ── Cache + rate limit (Upstash Redis, optional) ────────────────
# If unset, the app runs without caching/rate-limiting (no-op fallback).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── App ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
NODE_ENV="development"
# Active knowledge-base version served to new reports.
KB_VERSION="kb-v1"
# Ephemeris: "analytic" (pure JS, default) or "swiss" (Swiss Ephemeris, arc-second).
EPHEMERIS_PROVIDER="analytic"
