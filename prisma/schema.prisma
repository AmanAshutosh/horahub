// HoraHub database schema.
// Charts are deterministic given birth data, so they are cached by inputHash.
// Readings record which KB version produced them, so re-indexing never
// silently mutates an existing report.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  name         String?
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  profiles     Profile[]

  @@index([email])
}

/// A saved birth profile belonging to a user (a user can save many).
model Profile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName  String
  gender    Gender
  birthDate DateTime // stored as the resolved UTC instant of birth
  tzName    String // IANA timezone resolved at creation
  placeName String
  latitude  Float
  longitude Float
  charts    Chart[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// A computed chart. inputHash makes identical births a cache hit.
model Chart {
  id               String            @id @default(cuid())
  profileId        String?
  profile          Profile?          @relation(fields: [profileId], references: [id], onDelete: SetNull)
  inputHash        String            @unique
  facts            Json // serialized ChartFacts
  createdAt        DateTime          @default(now())
  readings         Reading[]
  reportBriefs     ReportBrief[]
  narrativeReports NarrativeReport[]

  @@index([profileId])
}

/// An interpretation rendered from a chart + a specific KB version.
model Reading {
  id         String   @id @default(cuid())
  chartId    String
  chart      Chart    @relation(fields: [chartId], references: [id], onDelete: Cascade)
  kbVersion  String
  sections   Json // serialized ReadingSection[]
  createdAt  DateTime @default(now())

  @@unique([chartId, kbVersion])
  @@index([chartId])
}

/// The deterministic structured brief (src/narrative/report-brief.ts's
/// ReportBrief) handed to the LLM — versioned like Reading, but keyed by an
/// extra briefVersion axis since this layer's shape (unlike KB rule
/// matching) is expected to evolve across this project's phases.
model ReportBrief {
  id               String            @id @default(cuid())
  chartId          String
  chart            Chart             @relation(fields: [chartId], references: [id], onDelete: Cascade)
  kbVersion        String
  briefVersion     String // bump when src/narrative/report-brief.ts's ReportBrief shape changes materially
  data             Json // serialized ReportBrief
  createdAt        DateTime          @default(now())
  narrativeReports NarrativeReport[]

  @@unique([chartId, kbVersion, briefVersion])
  @@index([chartId])
}

/// The final LLM-generated narrative report — the user-facing prose output
/// of src/llm/generate-report.ts's generateNarrativeReport(). Cache key is
/// more granular than Reading's: LLM output isn't perfectly deterministic
/// across model/prompt versions the way KB rule matching is, so a change to
/// either must produce a new row rather than silently reusing a stale one.
model NarrativeReport {
  id            String      @id @default(cuid())
  chartId       String
  chart         Chart       @relation(fields: [chartId], references: [id], onDelete: Cascade)
  reportBriefId String
  reportBrief   ReportBrief @relation(fields: [reportBriefId], references: [id], onDelete: Cascade)
  llmProvider   String // e.g. "anthropic"
  llmModel      String // exact model id used, for reproducibility/audit
  promptVersion String // bump when src/llm/prompts/* changes materially
  sections      Json // serialized NarrativeSections ({ overview, lifeDomains, mahadashas, antardashas })
  status        String      @default("complete") // "generating" | "complete" | "failed"
  createdAt     DateTime    @default(now())

  @@unique([chartId, reportBriefId, llmProvider, llmModel, promptVersion], map: "NarrativeReport_cache_key")
  @@index([chartId])
  @@index([reportBriefId])
}

/// A published, immutable snapshot of the knowledge base.
model KbVersion {
  id        String    @id @default(cuid())
  version   String    @unique // e.g. "kb-v1"
  notes     String?
  published Boolean   @default(false)
  createdAt DateTime  @default(now())
  rules     KbRule[]

  @@index([version])
}

/// A single encoded interpretation rule (the project's OWN wording).
model KbRule {
  id          String    @id @default(cuid())
  kbVersionId String
  kbVersion   KbVersion @relation(fields: [kbVersionId], references: [id], onDelete: Cascade)
  ruleKey     String // stable identifier, e.g. "planet.sig.Saturn"
  subject     String // "planet" | "house" | "dasha" | ...
  conditions  Json
  reading     String // original prose
  sourceWork  String // e.g. "BPHS"
  sourceRef   String // e.g. "Vol.1, Ch.3, v.14-15"
  tradition   String   @default("Parashari")

  @@unique([kbVersionId, ruleKey])
  @@index([subject])
}
